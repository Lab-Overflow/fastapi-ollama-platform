{
  "mode": "local",
  "ollama": {
    "pullModels": ["qwen2.5:0.5b", "nomic-embed-text"]
  },
  "env": {
    "OLLAMA_HOST": "http://127.0.0.1:11434",
    "CHAT_MODEL": "qwen2.5:0.5b",
    "EMBED_MODEL": "nomic-embed-text",
    "EXTRACT_MODEL": "qwen2.5:0.5b",
    "MAX_CONCURRENCY": "4",
    "REQUEST_TIMEOUT": "120",
    "LOG_LEVEL": "INFO",
    "SESSION_MAX_TURNS": "20",
    "SESSION_TTL_SECONDS": "3600",
    "SESSION_STORAGE_DIR": "data/sessions"
  },
  "local": {
    "python": "python3",
    "useVenv": true,
    "venvDir": ".venv",
    "autoCreateVenv": true,
    "autoInstallDeps": true,
    "autoStartOllama": true,
    "autoPullModels": true,
    "uvicornHost": "0.0.0.0",
    "uvicornPort": 8000,
    "reload": true
  },
  "docker": {
    "composeFile": "docker-compose.yml",
    "detached": true,
    "autoPullModels": true
  }
}
